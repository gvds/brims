# =============================================================================
# BRIMS — Production Environment Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.template .env
#   php artisan key:generate
#
# NEVER commit .env to version control — it contains secrets.
# After editing, run: php artisan optimize
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

APP_NAME="BRIMS"
APP_ENV=production
APP_KEY=                            # Run: php artisan key:generate
APP_DEBUG=false                     # Must be false in production
APP_URL=https://brims.example.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_CHANNEL=daily
LOG_LEVEL=warning                   # debug | info | notice | warning | error | critical | alert | emergency
LOG_DAILY_DAYS=14

# File deletion logging (set to false to disable)
LOG_ENABLE_DELETE=true
LOG_MAX_SIZE_KB=10240

# -----------------------------------------------------------------------------
# Database — Primary (MariaDB)
# -----------------------------------------------------------------------------

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brims
DB_USERNAME=brims
DB_PASSWORD=                        # Set a strong password

# -----------------------------------------------------------------------------
# Database — REDCap (read-only connection for importing REDCap data)
# Leave blank if REDCap integration is not used.
# -----------------------------------------------------------------------------

REDCAP_DB_HOST=redcap.database.server.address
REDCAP_DB_PORT=3306
REDCAP_DB_DATABASE=redcap
REDCAP_DB_USERNAME=redcap
REDCAP_DB_PASSWORD="redcap_password_here"

# REDCap web application base URL (used by the REDCap API client)
# REDCAP_URL=https://redcap.example.com/api

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------

CACHE_STORE=database

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------

QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------

FILESYSTEM_DISK=local

# Optional — S3-compatible object storage for large file uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------

MAIL_MAILER=smtp
MAIL_HOST=your.mail.server
MAIL_PORT=587
MAIL_USERNAME=your_mail_user
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="brims_admin@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# TUS server
# For resumable uploads of large files to S3 storage
# -----------------------------------------------------------------------------

TUS_ENDPOINT=https://tus_server.example.com/



VITE_APP_NAME="${APP_NAME}"

SYSTEM_ADMIN='username_of_brims_system_admin'

FPDF_FONTPATH="fonts"
