# =============================================================================
# BRIMS — Production Environment Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.template .env
#   php artisan key:generate
#
# NEVER commit .env to version control — it contains secrets.
# After editing, run: php artisan optimize
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

APP_NAME="BRIMS"
APP_ENV=production
APP_KEY=                            # Run: php artisan key:generate
APP_DEBUG=false                     # Must be false in production
APP_URL=https://brims.example.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_CHANNEL=daily
LOG_LEVEL=warning                   # debug | info | notice | warning | error | critical | alert | emergency
LOG_DAILY_DAYS=14

# File deletion logging (set to false to disable)
LOG_ENABLE_DELETE=true
LOG_MAX_SIZE_KB=10240

# -----------------------------------------------------------------------------
# Database — Primary (MariaDB)
# -----------------------------------------------------------------------------

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brims
DB_USERNAME=brims
DB_PASSWORD=                        # Set a strong password

# -----------------------------------------------------------------------------
# Database — REDCap (read-only connection for importing REDCap data)
# Leave blank if REDCap integration is not used.
# -----------------------------------------------------------------------------

# REDCAP_DB_HOST=127.0.0.1
# REDCAP_DB_PORT=3306
# REDCAP_DB_DATABASE=redcap
# REDCAP_DB_USERNAME=redcap_reader
# REDCAP_DB_PASSWORD=

# REDCap web application base URL (used by the REDCap API client)
# REDCAP_URL=https://redcap.example.com

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------

CACHE_STORE=database

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------

QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------

FILESYSTEM_DISK=local

# Optional — S3-compatible object storage for large file uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------

MAIL_MAILER=smtp
MAIL_HOST=your.mail.server
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=noreply@brims.example.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Laravel Telescope (debug assistant — disable in production)
# -----------------------------------------------------------------------------

TELESCOPE_ENABLED=false

# -----------------------------------------------------------------------------
# Redis (optional — alternative to database driver for cache/sessions/queues)
# -----------------------------------------------------------------------------

# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
