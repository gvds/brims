# =============================================================================
# BRIMS — Docker Local Development Environment
# =============================================================================
# Copy this file to .env before starting Docker Compose:
#
#   cp .env.docker .env
#   docker compose up -d
#   docker compose exec laravel.test php artisan key:generate
#   docker compose exec laravel.test php artisan migrate --seed
#   docker compose exec laravel.test php artisan storage:link
#
# The application will be available at http://localhost
# phpMyAdmin:  http://localhost:8080
# Mailpit:     http://localhost:8025
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

APP_NAME="BRIMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DAILY_DAYS=7

LOG_ENABLE_DELETE=true
LOG_MAX_SIZE_KB=10240

# -----------------------------------------------------------------------------
# Database — Primary (MariaDB via Docker service name)
# -----------------------------------------------------------------------------

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=brims
DB_USERNAME=sail
DB_PASSWORD=password

# -----------------------------------------------------------------------------
# Database — REDCap (leave blank if not used locally)
# -----------------------------------------------------------------------------

# REDCAP_DB_HOST=
# REDCAP_DB_PORT=3306
# REDCAP_DB_DATABASE=
# REDCAP_DB_USERNAME=
# REDCAP_DB_PASSWORD=
# REDCAP_URL=

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------

CACHE_STORE=database

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_SECURE_COOKIE=false
SESSION_ENCRYPT=false

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------

QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------

FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Mail (Mailpit — catches all mail locally, no real sending)
# -----------------------------------------------------------------------------

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Application-specific
# -----------------------------------------------------------------------------

SYSTEM_ADMIN=admin

FPDF_FONTPATH="fonts"

# TUS resumable uploads — leave blank if not used locally
# TUS_ENDPOINT=
